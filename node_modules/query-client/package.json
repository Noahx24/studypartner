{
  "version": "1.4.0",
  "description": "A lightweight and efficient query client for managing server state in JavaScript/TypeScript applications. Features include automatic caching, garbage collection, retry logic, and subscription-based updates.",
  "name": "query-client",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "author": "Ivan <pilmee@gmail.com>",
  "license": "MIT",
  "files": [
    "lib",
    "README.md",
    "LICENSE",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "jest --detectOpenHandles --testPathIgnorePatterns=\"__tests__/performance\"",
    "test:coverage": "jest --coverage --testPathIgnorePatterns=\"__tests__/performance\"",
    "test:json": "jest --json --outputFile=test-report.json --testPathIgnorePatterns=\"__tests__/performance\"",
    "test:performance": "jest __tests__/performance --runInBand",
    "docs": "typedoc --out docs src",
    "docs:build": "npm run docs",
    "semantic-release": "semantic-release"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^12.0.2",
    "@types/bun": "latest",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "semantic-release": "^24.2.9",
    "ts-jest": "^29.4.4",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "ssignal": "^1.2.0"
  },
  "exports": {
    "./query-client": {
      "types": "./lib/query-client.d.ts",
      "import": "./lib/query-client.es.js",
      "require": "./lib/query-client.cjs.js",
      "default": "./lib/query-client.cjs.js"
    },
    "./query-item": {
      "types": "./lib/query-item.d.ts",
      "import": "./lib/query-item.es.js",
      "require": "./lib/query-item.cjs.js",
      "default": "./lib/query-item.cjs.js"
    },
    "./query-fn": {
      "types": "./lib/query-fn.d.ts",
      "import": "./lib/query-fn.es.js",
      "require": "./lib/query-fn.cjs.js",
      "default": "./lib/query-fn.cjs.js"
    },
    "./query-client-config": {
      "types": "./lib/query-client-config.d.ts"
    },
    "./query-client-response": {
      "types": "./lib/query-client-response.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
